# Firebase 웹 앱 설정 (공개돼도 안전한 값들 — 보안은 Firebase 규칙이 담당).
# Firebase 콘솔 → 프로젝트 설정 → 일반 → 내 앱 → SDK 설정 및 구성 에서 복사.
# 로컬 실행: 이 파일을 .env 로 복사해 값을 채우고 `node --env-file=.env server.js` 로 구동.
# Railway: 아래 키들을 서비스 Variables 에 그대로 등록.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# PORT 는 Railway가 자동 주입한다. 로컬에서 바꾸려면만 설정.
# PORT=3000
