{
  "name": "chrono-zoetrope",
  "version": "1.0.0",
  "description": "A minimal Electron application with JavaScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "gen:library": "node scripts/generate-life-library.mjs --profile scripts/sample-profile.json",
    "admin": "node scripts/admin-server.mjs",
    "admin:view": "node scripts/admin-server.mjs --view-only",
    "gen:firestore": "node scripts/generate-from-firestore.mjs --once",
    "worker": "node scripts/generate-from-firestore.mjs --watch",
    "worker:listen": "node scripts/generate-from-firestore.mjs --listen",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.3.9",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.0.0",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "vite": "^7.2.6"
  }
}
