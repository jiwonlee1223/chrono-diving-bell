# Firebase 웹 config — chrono-diving-bell 프로젝트(chrono-zoetrope·profile-collector와 공유).
# 실제 값은 Firebase 콘솔 → 프로젝트 설정 → 일반 → 내 앱(웹)에서 복사해 .env로 채운다.
# 이 값들은 공개돼도 안전하다(보안은 Firebase 규칙이 담당). .env는 커밋하지 않는다.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
